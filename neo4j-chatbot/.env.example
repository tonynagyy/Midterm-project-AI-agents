# Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LLM Configuration
# Options: 'ollama', 'openai', 'groq', or 'lmstudio'
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS_DEFAULT=120
LLM_MAX_TOKENS_CLASSIFIER=8
LLM_MAX_TOKENS_CYPHER=220
LLM_MAX_TOKENS_RESPONSE=80
LLM_MAX_TOKENS_CHITCHAT=60

# Groq Specific (Get free key at https://groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Ollama Specific
OLLAMA_URL=http://localhost:11434/api/generate

# OpenAI Specific
OPENAI_API_KEY=your_openai_api_key_here

# LM Studio Specific
LMSTUDIO_URL=http://localhost:1234/v1/chat/completions

# Short-Term Conversation Memory
SHORT_MEMORY_TURNS=5
LONG_MEMORY_ENABLED=true
LONG_MEMORY_DB_PATH=data/long_memory.sqlite
LONG_MEMORY_RETRIEVE_ITEMS=4
LONG_MEMORY_MAX_CONTEXT_CHARS=1200

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/chatbot.log

# LangSmith Observability
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=neo4j-chatbot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
